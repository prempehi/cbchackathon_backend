# =============================================================================
#  Ghana Emergency Health Grid (GEHG) — Environment Configuration Template
#  Copy this file to `.env` and fill in all required values.
#  NEVER commit `.env` to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------

# Runtime environment: development | staging | production
APP_ENV=development

# Semantic version — mirrors FastAPI's displayed version
APP_VERSION=1.0.0

# Port exposed by the FastAPI process (Cloud Run injects PORT automatically)
PORT=8000

# -----------------------------------------------------------------------------
# CORS — React Frontend Origins
# Comma-separated list of allowed origins. No trailing slashes.
# Examples:
#   Development : http://localhost:3000
#   Staging     : https://gehg-staging.web.app
#   Production  : https://gehg.web.app,https://www.ghanaemergencygrid.org
# -----------------------------------------------------------------------------

ALLOWED_ORIGINS=http://localhost:3000

# -----------------------------------------------------------------------------
# Google / Firebase — Required in all environments
# -----------------------------------------------------------------------------

# Firebase project ID (visible in Firebase Console → Project Settings)
FIREBASE_PROJECT_ID=your-firebase-project-id

# Google Cloud region where Cloud Run and Firestore are deployed
GOOGLE_CLOUD_REGION=us-central1

# Path to the Firebase service-account JSON for local development.
# On Cloud Run, use Application Default Credentials (ADC) instead — leave blank.
GOOGLE_APPLICATION_CREDENTIALS=./serviceAccountKey.json

# -----------------------------------------------------------------------------
# Gemini 2.5 Flash — Triage AI Engine (Architecture §4.1)
# Obtain from: https://aistudio.google.com/app/apikey
# -----------------------------------------------------------------------------

GEMINI_API_KEY=your-gemini-api-key-here

# Gemini model identifier — update when promoting to a newer model
GEMINI_MODEL=gemini-2.5-flash

# Max output tokens for triage responses (keep low for latency)
GEMINI_MAX_TOKENS=1024

# -----------------------------------------------------------------------------
# Google Maps — Geo-Routing Service (Architecture §4.1, step 4)
# Requires: Distance Matrix API + Directions API enabled
# Obtain from: https://console.cloud.google.com/apis/credentials
# -----------------------------------------------------------------------------

GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here

# -----------------------------------------------------------------------------
# Firebase App Check (Architecture §7)
# Used to reject requests from unauthorised clients hitting the API.
# Set to the App Check debug token for local development.
# -----------------------------------------------------------------------------

FIREBASE_APP_CHECK_DEBUG_TOKEN=your-app-check-debug-token

# -----------------------------------------------------------------------------
# Security & Auth
# -----------------------------------------------------------------------------

# Secret used to sign any internal JWT tokens / session cookies
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-a-strong-random-secret

# Token expiry in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=60

# -----------------------------------------------------------------------------
# Logging & Monitoring (Architecture §8)
# -----------------------------------------------------------------------------

# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Set to true to emit structured JSON logs (recommended for Cloud Logging)
JSON_LOGS=false

# Sentry DSN — leave blank to disable error tracking locally
SENTRY_DSN=
